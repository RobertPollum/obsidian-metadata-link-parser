{
  "transformationConfig": {
    "rules": [
      {
        "id": "freedium-medium",
        "name": "Medium via Freedium",
        "enabled": true,
        "matchers": [
          "*.medium.com",
          "medium.com"
        ],
        "transformationType": "prefix",
        "template": "https://freedium-mirror.cfd/{url}",
        "priority": 100
      },
      {
        "id": "12ft-ladder",
        "name": "12ft Ladder (General Paywall Bypass)",
        "enabled": false,
        "matchers": [
          "*"
        ],
        "transformationType": "prefix",
        "template": "https://12ft.io/{url}",
        "priority": 10
      },
      {
        "id": "archive-today",
        "name": "Archive.today",
        "enabled": false,
        "matchers": [
          "*"
        ],
        "transformationType": "prefix",
        "template": "https://archive.is/{url}",
        "priority": 20
      }
    ],
    "proxyHealthCacheTtlMinutes": 5,
    "proxyHealthTimeoutMs": 5000,
    "autoProcessing": {
      "enabled": false,
      "folderPath": "",
      "frequencyMinutes": 60,
      "minContentLengthRatio": 2
    }
  }
}